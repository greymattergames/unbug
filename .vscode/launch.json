            },
            "cwd": "${workspaceFolder}/examples/macro",
            "presentation": {
                "group": "LLDB"
            }
        },

        {
            "name": "Windows debug example macro",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/debug/unbug_macro_example.exe",
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}/examples/macro",
            "preLaunchTask": "win_build_debug",
            "presentation": {
                "group": "Windows"
            }
        },

        {
            "name": "LLDB debug example bevy",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/unbug_bevy_example",
            "cargo": {
                "args": [
                    "build",
                    "--bin=unbug_bevy_example",
