{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LLDB debug example basic",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/unbug_basic_example",
            "cargo": {
                "args": [
                    "build",
                    "--bin=unbug_basic_example",
                    "--package=unbug_basic_example"
                ],
                "filter": {
                    "name": "unbug_basic_example",
                    "kind": "bin"
                }
            },
            "cwd": "${workspaceFolder}/examples/basic",
            "presentation": {
                "group": "LLDB"
            }
        },

        {
            "name": "Windows debug example basic",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/debug/unbug_basic_example.exe",
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}/examples/basic",
            "preLaunchTask": "win_build_debug",
            "presentation": {
                "group": "Windows"
            }
        },

        {
            "name": "LLDB debug example macro",
            "type": "lldb",
            "request": "launch",
