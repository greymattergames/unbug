{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cargo",
            "command": "build",
            "args": [
                "--bin=unbug_basic_example",
                "--package=unbug_basic_example"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "win_build_example",
        },
        {
            "label": "linux_build_example",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--bin=unbug_basic_example",
                "--package=unbug_basic_example"
            ],
            "env": {
                "CARGO_MANIFEST_DIR": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        }
    ]
}
