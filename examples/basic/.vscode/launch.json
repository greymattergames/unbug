{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LLDB debug",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=unbug_basic_example",
                    "--package=unbug_basic_example"
                ],
                "filter": {
                    "name": "unbug_basic_example",
                    "kind": "bin"
                }
            },
            "cwd": "${workspaceFolder}"
        },

        {
            "name": "Windows debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/debug/unbug_basic_example.exe",
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "win_build_debug"
        },

        {
            "name": "Linux debug",
            "type": "lldb",
            "preLaunchTask": "linux_build_debug",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/unbug_basic_example",
            "sourceLanguages": ["rust"],
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "LD_LIBRARY_PATH": "${workspaceFolder}/target/debug/deps:${env:LD_LIBRARY_PATH}"
            }
        }
    ]
}
